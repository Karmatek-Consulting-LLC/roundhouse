# Dev image: Python with uvicorn --reload. Code is bind-mounted.
FROM python:3.12-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
        netcat-openbsd \
        tar \
        curl \
        build-essential \
        libpq-dev \
    && rm -rf /var/lib/apt/lists/*

# ruff is shelled out from PythonFormatter to canonicalize generated server.py.
RUN pip install --no-cache-dir ruff

WORKDIR /app

COPY api/pyproject.toml /app/pyproject.toml
RUN pip install --no-cache-dir -e .

COPY api/docker/dev-entrypoint.sh /usr/local/bin/dev-entrypoint.sh
RUN chmod +x /usr/local/bin/dev-entrypoint.sh

EXPOSE 8000

ENTRYPOINT ["/usr/local/bin/dev-entrypoint.sh"]
CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"]
