# PostgreSQL
POSTGRES_USER=mcp
POSTGRES_PASSWORD=mcp
POSTGRES_DB=mcp

# Laravel app
# Generate a real key with: docker compose -f docker-compose.prod.yml run --rm platform php artisan key:generate --show
APP_KEY=
APP_DEBUG=false

# Initial admin account (created on first boot)
ADMIN_EMAIL=admin@mcp.local
ADMIN_PASSWORD=admin

# Platform
MCP_BASE_URL=http://localhost
DOCKER_NETWORK=mcp-network

# Swarm replica defaults (if running in Docker Swarm mode)
DEFAULT_MCP_SERVER_REPLICAS=1
MAX_MCP_SERVER_REPLICAS=32

# Ports (defaults are standard 80/443/8080)
# Override for local dev if those ports are in use:
# HTTP_PORT=3080
# HTTPS_PORT=3443
# DASHBOARD_PORT=3081
