# PostgreSQL
POSTGRES_USER=mcp
POSTGRES_PASSWORD=mcp
POSTGRES_DB=mcp

# Platform API
DATABASE_URL=postgresql://mcp:mcp@postgres:5432/mcp
JWT_SECRET_KEY=change-me-in-production
JWT_EXPIRE_MINUTES=1440

# Initial admin account (created on first boot)
ADMIN_EMAIL=admin@mcp.local
ADMIN_PASSWORD=admin

# Platform
MCP_BASE_URL=http://localhost:3080
DOCKER_NETWORK=mcp-network
