# Local development defaults. Copy to .env and edit if needed.
# For Swarm deploys: see docker-stack.yml.

# PostgreSQL
POSTGRES_USER=mcp
POSTGRES_PASSWORD=mcp
POSTGRES_DB=mcp

# Symmetric key used to encrypt per-server runtime tokens at rest. Format
# must be `base64:` followed by 32 random bytes, base64-encoded. Generate with:
#   printf 'base64:%s' "$(openssl rand -base64 32)"
# Leave blank for local dev (tokens stored unencrypted); set in any shared env.
APP_KEY=

# Initial admin account (seeded on first boot only if the users table is empty)
ADMIN_EMAIL=admin@mcp.local
ADMIN_PASSWORD=admin

# Platform
MCP_BASE_URL=http://localhost:3080
DOCKER_NETWORK=roundhouse-network

# Replica defaults. Only meaningful when targeting Docker Swarm; on the local
# single-daemon compose stack the platform always runs 1 task per server.
DEFAULT_MCP_SERVER_REPLICAS=1
MAX_MCP_SERVER_REPLICAS=32

# Docker backend mode. "auto" probes `docker info` to decide standalone vs
# swarm. Set to "standalone" when the host is a swarm node but the platform
# is running via `docker compose` (otherwise the API tries to manage Swarm
# services that conflict with the compose-owned containers).
# Values: auto | standalone | swarm
MCP_DOCKER_MODE=auto

# Host ports. Defaults dodge 80/8080 which are rarely free on a dev machine.
HTTP_PORT=3080
DASHBOARD_PORT=3081

# When the platform-api container stops (restart, compose down, etc.),
# should it tear down every managed MCP server? Default false - MCP
# servers are independent workloads and routine api restarts shouldn't
# kill them. Set true in CI / wipe-everything scripts; manual cleanup
# remains available via `docker exec platform-api python -m app.cleanup`.
# MCP_CLEANUP_ON_SHUTDOWN=false
